# PostgreSQL — local dev (default)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=insightflow
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable

# ── OR Supabase ──
# 1. Create project at https://supabase.com
# 2. Go to Project Settings → Database → Connection string
# 3. Copy the URI and fill in below
#
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=<your-supabase-db-password>
# DB_HOST=db.<your-project-ref>.supabase.co
# DB_PORT=6543
# DB_SSLMODE=require

# ClickHouse
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=clickhouse
CH_DATABASE=insightflow
CH_TABLE=events
