# PostgreSQL — local dev (individual fields)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=insightflow
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable

# ── OR Supabase (paste your connection string below, comment out fields above) ──
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:6543/postgres

# ClickHouse — local
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=clickhouse
CH_DATABASE=insightflow
CH_TABLE=events
CH_SECURE=false

# ── OR ClickHouse Cloud ──
# CH_HOST=YOUR_INSTANCE.clickhouse.cloud
# CH_PORT=9440
# CH_USER=default
# CH_PASSWORD=<your-clickhouse-cloud-password>
# CH_DATABASE=insightflow
# CH_TABLE=events
# CH_SECURE=true
