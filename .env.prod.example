# Django Settings
DJANGO_SECRET_KEY=generate-a-strong-random-key-for-production-here
DJANGO_DEBUG=False
ALLOWED_HOSTS=your_ec2_ip_or_domain,localhost,django

# External PostgreSQL (Supabase / AWS RDS)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres

# External ClickHouse (ClickHouse Cloud)
CH_HOST=your-clickhouse-host.clickhouse.cloud
CH_PORT=9440
CH_USER=default
CH_PASSWORD=your-clickhouse-password
CH_DATABASE=insightflow
CH_TABLE=events
CH_SECURE=true

# Local In-Docker Services (Do not change unless ports change)
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_EVENTS=events
KAFKA_CG_CLICKHOUSE=insightflow.clickhouse
KAFKA_CG_AGG=insightflow.aggregator
KAFKA_BATCH_SIZE=1000
KAFKA_BATCH_INTERVAL_MS=500
